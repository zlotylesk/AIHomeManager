{
  "info": {
    "name": "AIHomeManager API",
    "description": "Kolekcja Postman/Newman dla AIHomeManager REST API. Base URL: http://localhost:8080/api. Tasks CRUD (POST/GET/PUT/PATCH/DELETE single) pominiete — endpointy nie zaimplementowane (HMAI-43); zostal tylko /tasks/time-report. Music endpointy moga zwracac 503 gdy brak realnych kluczy Last.fm/Discogs w .env.local. Books ISBN-aware testy toleruja 503 gdy BN API jest nieosiagalne z kontenera.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "aihomemanager-v2-collection"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{api_key}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "api_key", "value": "e2e-test-key", "type": "string" },
    { "key": "series_id", "value": "", "type": "string" },
    { "key": "season_id", "value": "", "type": "string" },
    { "key": "episode_id", "value": "", "type": "string" },
    { "key": "book_id", "value": "", "type": "string" },
    { "key": "article_id", "value": "", "type": "string" },
    { "key": "today_article_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Series",
      "description": "Modul sledzenia i oceniania seriali",
      "item": [
        { "name": "GET - Lista seriali", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/series", "host": ["{{base_url}}"], "path": ["series"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Response is array', () => pm.expect(Array.isArray(pm.response.json())).to.be.true);"] } }] },
        { "name": "POST - Utworz serial", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Breaking Bad\"\n}" }, "url": { "raw": "{{base_url}}/series", "host": ["{{base_url}}"], "path": ["series"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has ID', () => { const body = pm.response.json(); pm.expect(body).to.have.property('id'); pm.collectionVariables.set('series_id', body.id); });"] } }] },
        { "name": "GET - Szczegoly serialu", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/series/{{series_id}}", "host": ["{{base_url}}"], "path": ["series", "{{series_id}}"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has title and seasons', () => { const body = pm.response.json(); pm.expect(body).to.have.property('title'); pm.expect(body).to.have.property('seasons'); pm.expect(body).to.have.property('averageRating'); });"] } }] },
        { "name": "GET - Szczegoly serialu (nie istnieje)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/series/00000000-0000-0000-0000-000000000000", "host": ["{{base_url}}"], "path": ["series", "00000000-0000-0000-0000-000000000000"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"] } }] },
        { "name": "POST - Dodaj sezon", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"number\": 1\n}" }, "url": { "raw": "{{base_url}}/series/{{series_id}}/seasons", "host": ["{{base_url}}"], "path": ["series", "{{series_id}}", "seasons"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has season ID', () => { const body = pm.response.json(); pm.expect(body).to.have.property('id'); pm.collectionVariables.set('season_id', body.id); });"] } }] },
        { "name": "POST - Dodaj odcinek z ocena", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Pilot\",\n  \"rating\": 9\n}" }, "url": { "raw": "{{base_url}}/series/{{series_id}}/seasons/{{season_id}}/episodes", "host": ["{{base_url}}"], "path": ["series", "{{series_id}}", "seasons", "{{season_id}}", "episodes"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has episode ID', () => { const body = pm.response.json(); pm.expect(body).to.have.property('id'); pm.collectionVariables.set('episode_id', body.id); });"] } }] },
        { "name": "POST - Odcinek z nieprawidlowa ocena", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test\",\n  \"rating\": 11\n}" }, "url": { "raw": "{{base_url}}/series/{{series_id}}/seasons/{{season_id}}/episodes", "host": ["{{base_url}}"], "path": ["series", "{{series_id}}", "seasons", "{{season_id}}", "episodes"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 422 dla oceny > 10', () => pm.response.to.have.status(422));"] } }] },
        { "name": "POST - Serial bez tytulu", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{}" }, "url": { "raw": "{{base_url}}/series", "host": ["{{base_url}}"], "path": ["series"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 422 dla braku tytulu', () => pm.response.to.have.status(422));"] } }] }
      ]
    },
    {
      "name": "Tasks",
      "description": "Tylko /tasks/time-report — CRUD endpointy (POST/GET/PUT/PATCH/DELETE) nie istnieja (HMAI-43)",
      "item": [
        { "name": "GET - Raport czasu", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/tasks/time-report?from=2025-01-01&to=2025-12-31", "host": ["{{base_url}}"], "path": ["tasks", "time-report"], "query": [{ "key": "from", "value": "2025-01-01" }, { "key": "to", "value": "2025-12-31" }] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has totalMinutes and totalHours', () => { const body = pm.response.json(); pm.expect(body).to.have.property('totalMinutes'); pm.expect(body).to.have.property('totalHours'); pm.expect(body).to.have.property('breakdown'); });"] } }] }
      ]
    },
    {
      "name": "Books",
      "description": "Biblioteka ksiazek. POST po ISBN wymaga National Library API — toleruje 503 gdy nieosiagalne.",
      "item": [
        { "name": "GET - Lista ksiazek", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/books", "host": ["{{base_url}}"], "path": ["books"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Response is array', () => pm.expect(Array.isArray(pm.response.json())).to.be.true);"] } }] },
        { "name": "GET - Lista ksiazek (filtr: reading)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/books?status=reading", "host": ["{{base_url}}"], "path": ["books"], "query": [{ "key": "status", "value": "reading" }] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('All books have status reading', () => { const books = pm.response.json(); books.forEach(b => pm.expect(b.status).to.equal('reading')); });"] } }] },
        { "name": "POST - Dodaj ksiazke po ISBN", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"isbn\": \"9788375780635\"\n}" }, "url": { "raw": "{{base_url}}/books", "host": ["{{base_url}}"], "path": ["books"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201 lub 503 (BN API)', () => pm.expect(pm.response.code).to.be.oneOf([201, 503]));", "if (pm.response.code === 201) { pm.test('Has metadata from BN API', () => { const body = pm.response.json(); pm.expect(body).to.have.property('id'); pm.expect(body).to.have.property('title'); pm.expect(body).to.have.property('author'); pm.collectionVariables.set('book_id', body.id); }); }"] } }] },
        { "name": "POST - Nieprawidlowy ISBN", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"isbn\": \"123\"\n}" }, "url": { "raw": "{{base_url}}/books", "host": ["{{base_url}}"], "path": ["books"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 422 lub 503 (walidacja ISBN albo BN API)', () => pm.expect(pm.response.code).to.be.oneOf([422, 503]));"] } }] },
        { "name": "GET - Szczegoly ksiazki", "event": [{ "listen": "prerequest", "script": { "exec": ["if (!pm.collectionVariables.get('book_id')) { pm.execution.skipRequest(); }"] } }, { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has percentage field', () => { const body = pm.response.json(); pm.expect(body).to.have.property('percentage'); pm.expect(body).to.have.property('readingProgress'); });"] } }], "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/books/{{book_id}}", "host": ["{{base_url}}"], "path": ["books", "{{book_id}}"] } } },
        { "name": "POST - Sesja czytania", "event": [{ "listen": "prerequest", "script": { "exec": ["if (!pm.collectionVariables.get('book_id')) { pm.execution.skipRequest(); }"] } }, { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Progress updated', () => { const body = pm.response.json(); pm.expect(body).to.have.property('currentPage'); pm.expect(body.currentPage).to.be.greaterThan(0); });"] } }], "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"pagesRead\": 30,\n  \"date\": \"2025-06-01\",\n  \"notes\": \"Test\"\n}" }, "url": { "raw": "{{base_url}}/books/{{book_id}}/reading-sessions", "host": ["{{base_url}}"], "path": ["books", "{{book_id}}", "reading-sessions"] } } },
        { "name": "DELETE - Usun ksiazke", "event": [{ "listen": "prerequest", "script": { "exec": ["if (!pm.collectionVariables.get('book_id')) { pm.execution.skipRequest(); }"] } }, { "listen": "test", "script": { "exec": ["pm.test('Status 204 lub 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"] } }], "request": { "method": "DELETE", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/books/{{book_id}}", "host": ["{{base_url}}"], "path": ["books", "{{book_id}}"] } } }
      ]
    },
    {
      "name": "Music",
      "description": "Last.fm / Discogs — toleruja 503 gdy w .env.local brak realnych kluczy",
      "item": [
        { "name": "GET - Top albumy Last.fm", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/music/top-albums?period=1month&limit=20", "host": ["{{base_url}}"], "path": ["music", "top-albums"], "query": [{ "key": "period", "value": "1month" }, { "key": "limit", "value": "20" }] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 lub 503 (brak Last.fm key)', () => pm.expect(pm.response.code).to.be.oneOf([200, 503]));", "if (pm.response.code === 200) { pm.test('Returns albums array', () => { const body = pm.response.json(); pm.expect(Array.isArray(body)).to.be.true; }); }"] } }] },
        { "name": "GET - Top albumy - nieprawidlowy period", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/music/top-albums?period=invalid", "host": ["{{base_url}}"], "path": ["music", "top-albums"], "query": [{ "key": "period", "value": "invalid" }] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 422 dla nieprawidlowego period', () => pm.response.to.have.status(422));"] } }] },
        { "name": "GET - Kolekcja Discogs", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/music/collection", "host": ["{{base_url}}"], "path": ["music", "collection"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 lub 503 (brak Discogs token)', () => pm.expect(pm.response.code).to.be.oneOf([200, 503]));", "if (pm.response.code === 200) { pm.test('Returns array', () => pm.expect(Array.isArray(pm.response.json())).to.be.true); }"] } }] },
        { "name": "GET - Porownanie Last.fm vs Discogs", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/music/comparison?period=1month&limit=50", "host": ["{{base_url}}"], "path": ["music", "comparison"], "query": [{ "key": "period", "value": "1month" }, { "key": "limit", "value": "50" }] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 lub 503 (brak Last.fm/Discogs)', () => pm.expect(pm.response.code).to.be.oneOf([200, 503]));", "if (pm.response.code === 200) { pm.test('Has all four sections', () => { const body = pm.response.json(); pm.expect(body).to.have.property('ownedAndListened'); pm.expect(body).to.have.property('wantList'); pm.expect(body).to.have.property('dustyShelf'); pm.expect(body).to.have.property('matchScore'); pm.expect(body.matchScore).to.be.within(0, 100); }); }"] } }] }
      ]
    },
    {
      "name": "Articles",
      "description": "Artykuly do przeczytania",
      "item": [
        { "name": "GET - Lista artykulow", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/articles", "host": ["{{base_url}}"], "path": ["articles"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Response is array', () => pm.expect(Array.isArray(pm.response.json())).to.be.true);"] } }] },
        { "name": "POST - Dodaj artykul", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Testowy artykul o PHP\",\n  \"url\": \"https://example.com/php-article\",\n  \"category\": \"technology\",\n  \"estimatedReadTime\": 10\n}" }, "url": { "raw": "{{base_url}}/articles", "host": ["{{base_url}}"], "path": ["articles"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has ID', () => { const body = pm.response.json(); pm.expect(body).to.have.property('id'); pm.collectionVariables.set('article_id', body.id); });"] } }] },
        { "name": "POST - Dodaj drugi artykul", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Drugi artykul\",\n  \"url\": \"https://example.com/second-article\",\n  \"category\": \"science\"\n}" }, "url": { "raw": "{{base_url}}/articles", "host": ["{{base_url}}"], "path": ["articles"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] } }] },
        { "name": "POST - Nieprawidlowy URL", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Artykul bez URL\",\n  \"url\": \"to-nie-jest-url\"\n}" }, "url": { "raw": "{{base_url}}/articles", "host": ["{{base_url}}"], "path": ["articles"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 422 dla nieprawidlowego URL', () => pm.response.to.have.status(422));"] } }] },
        { "name": "GET - Artykul na dzis (1)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/articles/today", "host": ["{{base_url}}"], "path": ["articles", "today"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has article data', () => { const body = pm.response.json(); pm.expect(body).to.have.property('id'); pm.expect(body).to.have.property('title'); pm.expect(body).to.have.property('url'); pm.collectionVariables.set('today_article_id', body.id); });"] } }] },
        { "name": "GET - Artykul na dzis (2 - cache check)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/articles/today", "host": ["{{base_url}}"], "path": ["articles", "today"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Same article as previous (cache idempotent)', () => { const body = pm.response.json(); pm.expect(body.id).to.equal(pm.collectionVariables.get('today_article_id')); });"] } }] },
        { "name": "POST - Oznacz na-dzis jako przeczytany", "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/articles/{{today_article_id}}/read", "host": ["{{base_url}}"], "path": ["articles", "{{today_article_id}}", "read"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }] },
        { "name": "GET - Artykul na dzis (po oznaczeniu)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/articles/today", "host": ["{{base_url}}"], "path": ["articles", "today"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 lub 204', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));", "if (pm.response.code === 200) { pm.test('Inny artykul (cache invalidated)', () => { const body = pm.response.json(); pm.expect(body.id).to.not.equal(pm.collectionVariables.get('today_article_id')); }); }"] } }] },
        { "name": "DELETE - Usun artykul", "request": { "method": "DELETE", "header": [{ "key": "Accept", "value": "application/json" }], "url": { "raw": "{{base_url}}/articles/{{article_id}}", "host": ["{{base_url}}"], "path": ["articles", "{{article_id}}"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 204 lub 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"] } }] }
      ]
    },
    {
      "name": "Auth",
      "description": "OAuth endpointy (poza firewallem /api). Newman musi byc uruchomiony z --ignore-redirects, inaczej HTTP klient policzy 200 z accounts.google.com zamiast 302 z naszej aplikacji.",
      "auth": { "type": "noauth" },
      "item": [
        { "name": "GET - Google OAuth start", "request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8080/auth/google", "host": ["http://localhost:8080"], "path": ["auth", "google"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 302', () => pm.response.to.have.status(302));", "pm.test('Location zawiera accounts.google.com', () => { const loc = pm.response.headers.get('Location') || ''; pm.expect(loc).to.include('accounts.google.com'); });"] } }] },
        { "name": "GET - Discogs OAuth start", "request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8080/auth/discogs", "host": ["http://localhost:8080"], "path": ["auth", "discogs"] } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 302 lub 502 (brak realnych Discogs creds)', () => pm.expect(pm.response.code).to.be.oneOf([302, 502]));", "if (pm.response.code === 302) { pm.test('Location zawiera discogs.com', () => { const loc = pm.response.headers.get('Location') || ''; pm.expect(loc).to.include('discogs.com'); }); }"] } }] }
      ]
    }
  ]
}
