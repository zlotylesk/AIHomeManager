###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://homemanager:homemanager@mysql:3306/homemanager?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages
###< symfony/messenger ###

REDIS_URL=redis://redis:6379

###> google-calendar ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
###< google-calendar ###

###> youtubeprogress ###
YOUTUBE_WATCHLIST_PLAYLIST_ID=
###< youtubeprogress ###

###> last.fm ###
LASTFM_API_KEY=
LASTFM_USERNAME=
###< last.fm ###

###> discogs ###
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_USERNAME=
DISCOGS_CALLBACK_URL=http://localhost:8080/auth/discogs/callback
###< discogs ###

###> trakt ###
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:8080/auth/trakt/callback
###< trakt ###

###> oauth-encryption ###
DISCOGS_TOKEN_KEY=
GOOGLE_TOKEN_KEY=
TRAKT_TOKEN_KEY=
###< oauth-encryption ###

###> monitoring ###
GRAYLOG_HOST=graylog
GRAYLOG_PORT=12201
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=AIHomeManager
###< monitoring ###

###> api-security ###
API_KEY=
###< api-security ###

###> symfony/lock ###

###> backup ###
BACKUP_DIR=/backups
###< backup ###
LOCK_DSN=redis://redis:6379
###< symfony/lock ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> notifications ###
# Single-user system: every notification goes from one sender to one inbox.
# Override both in .env.local together with a real MAILER_DSN.
NOTIFICATIONS_MAIL_FROM=aihm@localhost
NOTIFICATIONS_MAIL_TO=owner@localhost
###< notifications ###
