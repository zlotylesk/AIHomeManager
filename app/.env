###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://homemanager:homemanager@mysql:3306/homemanager?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages
###< symfony/messenger ###

REDIS_URL=redis://redis:6379

###> google-calendar ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
###< google-calendar ###

###> last.fm ###
LASTFM_API_KEY=
LASTFM_USERNAME=
###< last.fm ###

###> discogs ###
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_USERNAME=
DISCOGS_CALLBACK_URL=http://localhost:8080/auth/discogs/callback
# 32-byte key (base64-encoded) used to encrypt OAuth tokens at rest.
# Generate with: php -r "echo base64_encode(sodium_crypto_secretbox_keygen()), PHP_EOL;"
# Set the actual key in app/.env.local — do NOT commit a real value here.
DISCOGS_TOKEN_KEY=
###< discogs ###

###> monitoring ###
GRAYLOG_HOST=graylog
GRAYLOG_PORT=12201
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=AIHomeManager
###< monitoring ###

###> api-security ###
# Set the actual key in app/.env.local — do NOT commit a real value here.
API_KEY=
###< api-security ###
