<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <title>{{ block('subject') }}</title>
</head>
<body style="margin:0;padding:24px;background:#f5f5f5;font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#212121;">
<div style="max-width:560px;margin:0 auto;padding:24px;background:#ffffff;border-radius:8px;">
    <h1 style="margin:0 0 16px;font-size:18px;line-height:1.4;">{{ block('subject') }}</h1>
    {% block body %}{% endblock %}
    <p style="margin:24px 0 0;padding-top:16px;border-top:1px solid #eeeeee;font-size:12px;color:#757575;">
        AIHomeManager — powiadomienie automatyczne. Kanały i ciche godziny zmienisz w ustawieniach powiadomień.
    </p>
</div>
</body>
</html>
