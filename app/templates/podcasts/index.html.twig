{% extends 'base.html.twig' %}

{% block title %}Podcasty — AIHomeManager{% endblock %}

{% block body %}
<div class="app" data-controller="podcasts">
    <header class="app-header">
        <h1 class="app-title">Podcasty</h1>
        <div class="app-header-actions">
            <button class="btn btn-primary" data-action="click->podcasts#sync" data-podcasts-target="syncButton">Synchronizuj</button>
        </div>
    </header>

    <p class="podcasts-caveat" data-podcasts-target="caveat"></p>

    <section class="podcasts-section">
        <div id="podcasts-list" class="podcasts-list" data-podcasts-target="list">
            <div class="loading">Loading…</div>
        </div>
    </section>

    <section class="podcasts-section hidden" data-podcasts-target="detail"></section>
</div>
{% endblock %}
