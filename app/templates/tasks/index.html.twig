{% extends 'base.html.twig' %}

{% block title %}Tasks — AIHomeManager{% endblock %}

{% block body %}
<div class="app">
    <header class="app-header">
        <h1 class="app-title">Tasks</h1>
    </header>

    <section class="card">
        <h2 class="section-title">New Task</h2>
        <form id="form-create-task" class="time-report-form">
            <div class="form-group">
                <label for="task-title">Title</label>
                <input id="task-title" type="text" maxlength="255" required>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="task-start">Start</label>
                    <input id="task-start" type="datetime-local" required>
                </div>
                <div class="form-group">
                    <label for="task-end">End</label>
                    <input id="task-end" type="datetime-local" required>
                </div>
                <div class="form-group form-group--action">
                    <button type="submit" class="btn btn-primary">Create Task</button>
                </div>
            </div>
        </form>
    </section>

    <section class="card">
        <h2 class="section-title">All tasks</h2>
        <div class="form-group">
            <label for="task-filter-status">Filter by status</label>
            <select id="task-filter-status">
                <option value="">All</option>
                <option value="pending">Pending</option>
                <option value="completed">Completed</option>
                <option value="cancelled">Cancelled</option>
            </select>
        </div>
        <div id="tasks-loading" class="loading">Loading tasks…</div>
        <table class="data-table hidden" id="tasks-table">
            <thead>
                <tr><th>Title</th><th>Start</th><th>End</th><th>Duration</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody></tbody>
        </table>
        <div id="tasks-empty" class="empty-state hidden">No tasks yet.</div>
    </section>

    <section class="card">
        <h2 class="section-title">Time Report</h2>
        <form id="form-time-report" class="time-report-form">
            <div class="form-row">
                <div class="form-group">
                    <label for="input-from">From</label>
                    <input id="input-from" type="date" required>
                </div>
                <div class="form-group">
                    <label for="input-to">To</label>
                    <input id="input-to" type="date" required>
                </div>
                <div class="form-group form-group--action">
                    <button type="submit" class="btn btn-primary">Generate Report</button>
                </div>
            </div>
        </form>
    </section>

    <div id="report-result" class="hidden">
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-value" id="stat-hours">—</div>
                <div class="stat-label">Total hours</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="stat-minutes">—</div>
                <div class="stat-label">Total minutes</div>
            </div>
        </div>
        <div class="card">
            <h2 class="section-title">Breakdown</h2>
            <table class="data-table" id="breakdown-table">
                <thead><tr><th>Task</th><th>Minutes</th><th>Hours</th></tr></thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div id="report-empty" class="empty-state hidden">No tasks found in selected period.</div>
</div>

<div id="task-detail-modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="detail-title">
    <div class="modal-box">
        <h2 id="detail-title">Task details</h2>
        <dl class="detail-list">
            <dt>Status</dt><dd id="detail-status">—</dd>
            <dt>Start</dt><dd id="detail-start">—</dd>
            <dt>End</dt><dd id="detail-end">—</dd>
            <dt>Duration</dt><dd id="detail-duration">—</dd>
            <dt>Google Calendar</dt><dd id="detail-google">—</dd>
        </dl>
        <div class="form-actions">
            <button type="button" class="btn btn-secondary js-detail-close">Close</button>
        </div>
    </div>
</div>

<div id="task-edit-modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="edit-title">
    <div class="modal-box">
        <h2 id="edit-title">Edit task</h2>
        <form id="form-edit-task">
            <input type="hidden" id="edit-task-id">
            <div class="form-group">
                <label for="edit-task-title">Title</label>
                <input id="edit-task-title" type="text" maxlength="255" required>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="edit-task-start">Start</label>
                    <input id="edit-task-start" type="datetime-local" required>
                </div>
                <div class="form-group">
                    <label for="edit-task-end">End</label>
                    <input id="edit-task-end" type="datetime-local" required>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary js-edit-close">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script src="{{ asset('js/util.js') }}"></script>
<script src="{{ asset('js/tasks.js') }}"></script>
{% endblock %}
