{% extends 'base.html.twig' %}

{% block title %}Articles — AIHomeManager{% endblock %}

{% block body %}
<div class="app">
    <header class="app-header">
        <h1 class="app-title">Articles</h1>
        <div class="header-actions">
            <select id="filter-category" class="select-filter">
                <option value="">All categories</option>
            </select>
        </div>
    </header>

    <section class="card">
        <h2 class="section-title">New Article</h2>
        <form id="form-create-article" class="time-report-form">
            <div class="form-group">
                <label for="article-title">Title</label>
                <input id="article-title" type="text" maxlength="255" required>
            </div>
            <div class="form-group">
                <label for="article-url">URL</label>
                <input id="article-url" type="url" required>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="article-category">Category</label>
                    <input id="article-category" type="text" maxlength="255">
                </div>
                <div class="form-group">
                    <label for="article-read-time">Read time (min)</label>
                    <input id="article-read-time" type="number" min="1">
                </div>
                <div class="form-group form-group--action">
                    <button type="submit" class="btn btn-primary">Add Article</button>
                </div>
            </div>
        </form>
    </section>

    <div id="today-section" class="hidden">
        <h2 class="section-title">Today's Article</h2>
        <div id="today-article"></div>
    </div>

    <h2 class="section-title" style="margin-top:1.5rem">All Articles</h2>
    <div id="articles-list" class="articles-list">
        <div class="loading">Loading…</div>
    </div>
</div>

<script src="{{ asset('js/util.js') }}"></script>
<script src="{{ asset('js/articles.js') }}"></script>
{% endblock %}
