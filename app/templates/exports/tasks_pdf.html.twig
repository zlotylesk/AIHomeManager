<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: "DejaVu Sans", sans-serif; font-size: 10pt; }
        h1 { font-size: 16pt; margin-bottom: 8pt; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #333; padding: 4pt 6pt; text-align: left; }
        th { background-color: #e0e0e0; font-weight: bold; }
        .right { text-align: right; }
        .footer { margin-top: 10pt; font-size: 8pt; color: #666; }
    </style>
</head>
<body>
    <h1>Tasks Export</h1>
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Start Time</th>
                <th>End Time</th>
                <th class="right">Duration (min)</th>
                <th>Google Event ID</th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
            <tr>
                <td>{{ row.title }}</td>
                <td>{{ row.startTime }}</td>
                <td>{{ row.endTime }}</td>
                <td class="right">{{ row.durationMinutes }}</td>
                <td>{{ row.googleEventId }}</td>
            </tr>
            {% else %}
            <tr><td colspan="5">No tasks found.</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <p class="footer">Generated {{ 'now'|date('Y-m-d H:i') }} &mdash; AIHomeManager</p>
</body>
</html>
