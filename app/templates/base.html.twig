<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}AIHomeManager{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏠</text></svg>">
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body>
        <nav class="navbar">
            <a class="navbar-brand" href="{{ path('app_frontend_series') }}">🏠 AIHomeManager</a>
            <ul class="navbar-links">
                <li><a href="{{ path('app_frontend_series') }}" {% if app.request.attributes.get('_route') == 'app_frontend_series' %}class="active"{% endif %}>Series</a></li>
                <li><a href="{{ path('app_frontend_tasks') }}" {% if app.request.attributes.get('_route') == 'app_frontend_tasks' %}class="active"{% endif %}>Tasks</a></li>
                <li><a href="{{ path('app_frontend_books') }}" {% if app.request.attributes.get('_route') == 'app_frontend_books' %}class="active"{% endif %}>Books</a></li>
                <li><a href="{{ path('app_frontend_articles') }}" {% if app.request.attributes.get('_route') == 'app_frontend_articles' %}class="active"{% endif %}>Articles</a></li>
                <li><a href="{{ path('app_frontend_music') }}" {% if app.request.attributes.get('_route') == 'app_frontend_music' %}class="active"{% endif %}>Music</a></li>
            </ul>
        </nav>

        <div id="error-banner" class="error-banner hidden"></div>

        {% block body %}{% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </body>
</html>
