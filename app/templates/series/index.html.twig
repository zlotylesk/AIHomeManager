{% extends 'base.html.twig' %}

{% block title %}Series — AIHomeManager{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
{% endblock %}

{% block body %}
<div class="app">
    <header class="app-header">
        <h1 class="app-title">Series</h1>
        <button class="btn btn-primary" id="btn-add-series">+ Add Series</button>
    </header>

    <div id="modal-add-series" class="modal hidden">
        <div class="modal-box">
            <h2>New Series</h2>
            <form id="form-add-series">
                <label for="input-series-title">Title</label>
                <input id="input-series-title" type="text" placeholder="e.g. Breaking Bad" required autofocus>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <button type="button" class="btn btn-secondary" id="btn-cancel-series">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <main class="app-main">
        <section id="series-list-view">
            <div id="series-list" class="series-grid">
                <div class="loading">Loading…</div>
            </div>
        </section>

        <section id="series-detail-view" class="hidden">
            <button class="btn btn-secondary back-btn" id="btn-back">← Back to list</button>
            <div id="series-detail-content"></div>
        </section>
    </main>
</div>

<script src="{{ asset('js/util.js') }}"></script>
<script src="{{ asset('js/series.js') }}"></script>
{% endblock %}
