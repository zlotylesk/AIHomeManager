{% extends 'base.html.twig' %}

{% block title %}Series — AIHomeManager{% endblock %}

{% block body %}
<div class="app" data-controller="series">
    <header class="app-header">
        <h1 class="app-title">Series</h1>
        <div class="header-actions">
            <button class="btn btn-secondary" id="btn-import-trakt">Import from Trakt</button>
            <button class="btn btn-primary" id="btn-add-series">+ Add Series</button>
        </div>
    </header>

    <div id="modal-add-series" class="modal hidden">
        <div class="modal-box">
            <h2>New Series</h2>
            <form id="form-add-series">
                <label for="input-series-title">Title</label>
                <input id="input-series-title" type="text" placeholder="e.g. Breaking Bad" required autofocus>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <button type="button" class="btn btn-secondary" id="btn-cancel-series">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <main class="app-main">
        <section id="series-list-view">
            <div id="series-toolbar" class="series-toolbar hidden">
                <input type="search" id="series-search" class="series-search"
                       placeholder="Search series…" aria-label="Search series by title" autocomplete="off">
                <label class="series-sort-label">Sort:
                    <select id="series-sort" class="series-sort" aria-label="Sort series">
                        <option value="title">Title A–Z</option>
                        <option value="rating-desc">Average ★ ↓</option>
                        <option value="own-desc">My rating ★ ↓</option>
                        <option value="created-desc">Recently added</option>
                    </select>
                </label>
            </div>
            <div id="series-list" class="series-grid">
                <div class="loading">Loading…</div>
            </div>
        </section>

        <section id="series-detail-view" class="hidden">
            <button class="btn btn-secondary back-btn" id="btn-back">← Back to list</button>
            <div id="series-detail-content"></div>
        </section>
    </main>
</div>
{% endblock %}
