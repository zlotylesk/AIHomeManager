# Test-only placeholders — GoogleClientFactory validates these at construction
# (HMAI-90), so the kernel cannot boot with empty values. Real values come from
# .env.local in dev/prod.
GOOGLE_CLIENT_ID='test-google-client-id'
GOOGLE_CLIENT_SECRET='test-google-client-secret'
GOOGLE_REDIRECT_URI='https://localhost/auth/google/callback'

# DiscogsCredentials VO (HMAI-113) rejects empty values for the same reason —
# the controller cannot be wired without a usable pair.
DISCOGS_CONSUMER_KEY='test-discogs-consumer-key'
DISCOGS_CONSUMER_SECRET='test-discogs-consumer-secret'

# Trakt OAuth2 placeholders (HMAI-180) — non-empty so TraktAuthController and
# TraktTokenProvider can be wired in tests.
TRAKT_CLIENT_ID='test-trakt-client-id'
TRAKT_CLIENT_SECRET='test-trakt-client-secret'
TRAKT_REDIRECT_URI='https://localhost/auth/trakt/callback'

BACKUP_DIR='/tmp/aihm_backup_test'

# YouTubeProgress sync target (HMAI-173). Non-empty so the /sync endpoint reaches
# command dispatch in tests; the empty-config 400 path restarts the kernel with
# this unset.
YOUTUBE_WATCHLIST_PLAYLIST_ID='PLtestwatchlist'
