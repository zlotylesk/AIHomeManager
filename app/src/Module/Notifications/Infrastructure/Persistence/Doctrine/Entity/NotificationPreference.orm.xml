<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Module\Notifications\Domain\Entity\NotificationPreference" table="notification_preferences">
        <unique-constraints>
            <unique-constraint columns="type" name="uniq_notification_preferences_type"/>
        </unique-constraints>
        <id name="id" type="string" column="id" length="36"/>
        <field name="type" type="notification_type" column="type" length="50" nullable="false"/>
        <field name="enabled" type="boolean" column="enabled" nullable="false">
            <options>
                <option name="default">1</option>
            </options>
        </field>
        <field name="channels" type="json" column="channels" nullable="false"/>
        <field name="quietHours" type="quiet_hours" column="quiet_hours" length="11" nullable="true"/>
    </entity>

</doctrine-mapping>
