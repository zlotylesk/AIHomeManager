<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Module\Articles\Domain\Entity\Article" table="articles">
        <unique-constraints>
            <unique-constraint columns="url" name="uniq_articles_url"/>
        </unique-constraints>
        <id name="id" type="string" column="id" length="36"/>
        <field name="title" type="string" column="title" length="500" nullable="false"/>
        <embedded name="url" class="App\Module\Articles\Domain\ValueObject\ArticleUrl" use-column-prefix="false"/>
        <field name="category" type="string" column="category" length="255" nullable="true"/>
        <field name="estimatedReadTime" type="integer" column="estimated_read_time" nullable="true"/>
        <field name="addedAt" type="datetime_immutable" column="added_at" nullable="false"/>
        <field name="readAt" type="datetime_immutable" column="read_at" nullable="true"/>
        <field name="isRead" type="boolean" column="is_read" nullable="false"/>
    </entity>

</doctrine-mapping>
