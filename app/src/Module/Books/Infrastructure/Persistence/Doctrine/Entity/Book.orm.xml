<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Module\Books\Domain\Entity\Book" table="books">
        <unique-constraints>
            <unique-constraint columns="isbn" name="uniq_books_isbn"/>
        </unique-constraints>
        <indexes>
            <index name="idx_books_status" columns="status"/>
        </indexes>
        <id name="id" type="string" column="id" length="36"/>
        <embedded name="isbn" class="App\Module\Books\Domain\ValueObject\ISBN" use-column-prefix="false"/>
        <field name="title" type="string" column="title" length="500" nullable="false"/>
        <field name="author" type="string" column="author" length="255" nullable="false"/>
        <field name="publisher" type="string" column="publisher" length="255" nullable="false"/>
        <field name="year" type="integer" column="year" nullable="false"/>
        <field name="coverUrl" type="string" column="cover_url" length="1000" nullable="true"/>
        <embedded name="readingProgress" class="App\Module\Books\Domain\ValueObject\ReadingProgress" use-column-prefix="false"/>
        <field name="status" type="book_status" column="status" length="50" nullable="false"/>
    </entity>

</doctrine-mapping>
