<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Module\Podcasts\Domain\Entity\PodcastListeningSession" table="podcast_listening_sessions">
        <unique-constraints>
            <unique-constraint columns="dedup_hash" name="uniq_podcast_sessions_dedup"/>
        </unique-constraints>
        <indexes>
            <index name="idx_podcast_sessions_listened_at" columns="listened_at"/>
            <index name="idx_podcast_sessions_episode" columns="episode_id"/>
        </indexes>
        <id name="id" type="string" column="id" length="36"/>
        <field name="podcastId" type="string" column="podcast_id" length="36" nullable="false"/>
        <field name="episodeId" type="string" column="episode_id" length="36" nullable="false"/>
        <field name="listenedAt" type="datetime_immutable" column="listened_at" nullable="false"/>
        <embedded name="progress" class="App\Module\Podcasts\Domain\ValueObject\ListeningProgress" use-column-prefix="false"/>
        <field name="dedupHash" type="string" column="dedup_hash" length="64" nullable="false"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
    </entity>

</doctrine-mapping>
