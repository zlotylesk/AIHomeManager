<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Module\Podcasts\Domain\Entity\Episode" table="podcast_episodes">
        <unique-constraints>
            <unique-constraint columns="external_id" name="uniq_podcast_episodes_external"/>
        </unique-constraints>
        <indexes>
            <index name="idx_podcast_episodes_podcast" columns="podcast_id"/>
        </indexes>
        <id name="id" type="string" column="id" length="36"/>
        <field name="podcastId" type="string" column="podcast_id" length="36" nullable="false"/>
        <embedded name="title" class="App\Module\Podcasts\Domain\ValueObject\Title" use-column-prefix="false"/>
        <field name="externalId" type="string" column="external_id" length="255" nullable="true"/>
        <field name="publishedAt" type="datetime_immutable" column="published_at" nullable="true"/>
        <field name="durationMs" type="integer" column="duration_ms" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
    </entity>

</doctrine-mapping>
